#!/usr/bin/env bash
# Pre-push: validate roadmap docs, check drift, install user skill and binary

remote="${1:-}"
REPO_ROOT="$(git rev-parse --show-toplevel)"

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip delete pushes
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Validate docs/roadmap/ if changed and rootline is available.
  if git diff --name-only "$range" -- docs/roadmap/ 2>/dev/null | grep -q . && [ -d docs/roadmap/ ]; then
    echo "Validating docs/roadmap/ before push..."
    if command -v rootline >/dev/null 2>&1; then
      if ! rootline validate --all docs/roadmap/ >/dev/null 2>&1; then
        echo "rootline validate --all docs/roadmap/ failed. Fix errors before pushing." >&2
        echo "Run: rootline validate --all docs/roadmap/" >&2
        echo "Or:  rootline fix --all docs/roadmap/" >&2
        exit 1
      fi
      echo "docs/roadmap/ validation passed"
    else
      echo "Warning: rootline not installed, skipping docs/roadmap validation" >&2
    fi
  fi

  # If roadmapctl command code changed, docs or the roadmap skill should change too.
  if git diff --name-only "$range" -- cmd/ internal/ 2>/dev/null | grep -q .; then
    missing=""
    if ! git diff --name-only "$range" -- docs/ README.md AGENTS.md 2>/dev/null | grep -q .; then
      missing="docs"
    fi
    if ! git diff --name-only "$range" -- .claude/skills/roadmap/ 2>/dev/null | grep -q .; then
      missing="${missing:+$missing + }skills"
    fi
    if [ -n "$missing" ]; then
      echo "roadmapctl code changed but $missing were not updated." >&2
      echo "Update docs/README/AGENTS and/or .claude/skills/roadmap before pushing." >&2
      exit 1
    fi
  fi

  # If CI, release, install, hooks, or build config changed, docs should be updated too.
  if git diff --name-only "$range" -- .github/ .goreleaser.yml .githooks/ scripts/ go.mod go.sum 2>/dev/null | grep -q .; then
    if ! git diff --name-only "$range" -- README.md docs/ AGENTS.md 2>/dev/null | grep -q .; then
      echo "CI/scripts/hooks/build config changed but docs were not updated." >&2
      echo "Update README.md, docs/, or AGENTS.md before pushing." >&2
      exit 1
    fi
  fi
done

# Install the user-scope skill and rebuild the user-scope roadmapctl binary.
# This mirrors rootline/backscroll: local pushes leave the user tools current.
"$REPO_ROOT/scripts/install-user.sh"
