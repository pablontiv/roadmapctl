version: 2
scope:
  match: "roadmap.local.md"

schema:
  roadmap-root:
    type: string
    required: true
  done-statuses:
    type: list
    required: true
  active-statuses:
    type: list
    required: true
  status-values:
    type: map
    required: true
  leaf-filter:
    type: string
  outcome-close-verify:
    type: list
  pr-merge-strategy:
    type: enum
    values: [squash, merge, rebase]
  commit-style:
    type: enum
    values: [conventional]
  auto-push:
    type: bool

validate:
  - field: roadmap-root
    rule: non_empty
